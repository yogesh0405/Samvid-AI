# Samvid AI - Frontend Environment Variables
# Copy this file to .env.local for local development

# API Gateway base URL (from SAM deploy output)
VITE_API_BASE_URL=https://YOUR_API_ID.execute-api.ap-south-1.amazonaws.com/dev/api/v1

# For local development with SAM local
# VITE_API_BASE_URL=http://localhost:3001/api/v1
