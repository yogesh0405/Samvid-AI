# Samvid AI - Backend Environment Variables
# For local development with SAM local (sam local start-api)

# Core AWS Resources (auto-set in SAM template for deployed envs)
DOCUMENTS_TABLE=samvid-ai-documents-dev
DOCUMENTS_BUCKET=samvid-ai-documents-dev-YOUR_ACCOUNT_ID
AUDIO_BUCKET=samvid-ai-audio-dev-YOUR_ACCOUNT_ID

# OpenAI (use this for local dev; production uses Secrets Manager)
OPENAI_API_KEY=sk-...your-openai-api-key...
OPENAI_SECRET_NAME=samvid-ai/openai-api-key

# Environment
ENVIRONMENT=dev
LOG_LEVEL=INFO

# AWS region (defaults to ap-south-1 for India)
AWS_DEFAULT_REGION=ap-south-1

# Local development only
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
